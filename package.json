{
  "name": "redactenv-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Secret redaction package suite for Node.js servers",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "rm -rf packages/*/dist packages/*/node_modules examples/*/node_modules node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "@types/node": "^22.9.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
