{
  "name": "@redactenv/express",
  "version": "0.1.0",
  "description": "Express/Connect middleware that redacts secrets from outgoing responses",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
