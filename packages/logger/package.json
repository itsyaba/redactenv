{
  "name": "@redactenv/logger",
  "version": "0.1.0",
  "description": "Logger adapters: pino transport + console patcher that redact secrets",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./console": {
      "types": "./dist/console.d.ts",
      "import": "./dist/console.js"
    },
    "./pino": {
      "types": "./dist/pino.d.ts",
      "import": "./dist/pino.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@redactenv/core": "0.1.0"
  },
  "license": "MIT"
}
